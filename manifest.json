{
    "manifest_version": 3,
    "name": "Open Gemini Tag Selector",
    "version": "1.1",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://gemini.google.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}